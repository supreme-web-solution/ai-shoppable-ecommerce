APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_video_ecommerce
DB_USERNAME=root
DB_PASSWORD=

# Local Laragon without phpredis: use file/database drivers below.
# Production: SESSION_DRIVER=redis, CACHE_STORE=redis, QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

REDIS_QUEUE=default
QUEUE_DEFAULT=default
QUEUE_CRITICAL=critical
QUEUE_REALTIME=realtime
QUEUE_MEDIA=media
QUEUE_AI=ai
QUEUE_EMBEDDINGS=embeddings
QUEUE_WEBHOOKS=webhooks
QUEUE_INTEGRATION=integration
QUEUE_ANALYTICS=analytics

REVERB_APP_ID=ai-video-commerce
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_WEBHOOK_SECRET=

WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=
WOO_WEBHOOK_SECRET=

HORIZON_ALLOWED_EMAILS=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

HEYGEN_API_KEY=
HEYGEN_DEFAULT_AVATAR_ID=
HEYGEN_DEFAULT_VOICE_ID=
HEYGEN_CACHE_TTL_SECONDS=21600
# Send product placement to HeyGen (watermark + motion prompt). UI stays visible when false for testing.
# Set true after HeyGen enables custom watermark on your workspace.
HEYGEN_WATERMARK_ENABLED=false
AI_AVATAR_POLL_ATTEMPTS=60
AI_AVATAR_POLL_SLEEP_SECONDS=10

AI_DEFAULT_AVATAR_DURATION=45
AI_AVATAR_POLL_ATTEMPTS=12

VITE_APP_NAME="${APP_NAME}"


# Run dedicated workers (separation of concerns):
# php artisan queue:work redis --queue=critical --tries=3 --timeout=90
# php artisan queue:work redis --queue=realtime --tries=3 --timeout=90
# php artisan queue:work redis --queue=media --tries=3 --timeout=600
# php artisan queue:work redis --queue=ai --tries=5 --timeout=900
# php artisan queue:work redis --queue=embeddings --tries=5 --timeout=900
# php artisan queue:work redis --queue=webhooks --tries=5 --timeout=120
# php artisan queue:work redis --queue=integration --tries=5 --timeout=120
# php artisan queue:work redis --queue=analytics --tries=5 --timeout=120
# php artisan queue:work redis --queue=default --tries=3 --timeout=120